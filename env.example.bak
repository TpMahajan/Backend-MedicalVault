# -------------------- Server --------------------
PORT=5000
NODE_ENV=development
BASE_URL=https://your-backend-url.com
WEB_APP_URL=https://medicalvault-aially.vercel.app
CORS_ORIGINS=https://medicalvault-aially.vercel.app,https://health-vault-web.vercel.app
CORS_ORIGIN_PATTERNS=^https:\\/\\/medicalvault-aially(?:-[a-z0-9-]+)?\\.vercel\\.app$,^https:\\/\\/health-vault-web(?:-[a-z0-9-]+)?\\.vercel\\.app$

# -------------------- Database --------------------
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority&appName=appname

# -------------------- Auth --------------------
JWT_SECRET=replace-with-random-secret-at-least-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace-with-random-refresh-secret-at-least-32-chars-long
# 32-byte encryption key for sensitive profile fields (64 hex chars or base64)
DATA_ENCRYPTION_KEY=replace-with-64-char-hex-key

# -------------------- SuperAdmin --------------------
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_BOOTSTRAP_PASSWORD=replace-with-strong-temporary-bootstrap-password

# -------------------- Uploads --------------------
UPLOAD_DIR=uploads

# -------------------- AWS S3 --------------------
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=your-s3-bucket-name

# -------------------- Firebase Admin SDK (for FCM) --------------------
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<replace-with-private-key>\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-fbsvc%40medicalvaultnotifications.iam.gserviceaccount.com

# -------------------- Rate Limiting --------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -------------------- Cloudinary (Legacy - can be removed) --------------------
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
